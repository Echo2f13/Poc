# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=app_dev
DATABASE_USER=dev
DATABASE_PASSWORD=dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT (Phase 2)
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# Payment Simulation (Phase 4)
PAYMENT_CARD_SUCCESS_RATE=80
PAYMENT_UPI_SUCCESS_RATE=90
PAYMENT_MIN_DELAY_MS=2000
PAYMENT_MAX_DELAY_MS=5000
